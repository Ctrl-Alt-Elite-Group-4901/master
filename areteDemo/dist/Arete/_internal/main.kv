#:kivy 2.2.0
#:import FadeTransition kivy.uix.screenmanager.FadeTransition

# ===== WIDGET TEMPLATES =====
<Header@BoxLayout>:
    size_hint_y: None
    height: dp(60)
    padding: dp(10)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: app.theme_header
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: "Arete App"
        bold: True
        font_size: "20sp"
        color: 1, 1, 1, 1

<Footer@BoxLayout>:
    size_hint_y: None
    height: dp(50)
    padding: dp(10)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: app.theme_footer
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: "© Arete - ver 1.3"
        font_size: "14sp"
        color: 0.3, 0.3, 0.3, 1

# ===== SCREEN DEFINITIONS =====

<Login>:
    name: "login"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        BoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(10)
            Label:
                text: "Login"
                font_size: "24sp"
                color: 0, 0, 0, 1
                size_hint_y: None
                height: dp(40)
            TextInput:
                id: email
                hint_text: "Email"
                multiline: False
            TextInput:
                id: password
                hint_text: "Password"
                password: True
                multiline: False
            Button:
                text: "Login"
                size_hint_y: None
                height: dp(44)
                on_release: root.login_user()
            Button:
                text: "Sign Up"
                size_hint_y: None
                height: dp(44)
                on_release: root.go_to_signup()
        Footer:

<Register>:
    name: "register"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        BoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(10)
            Label:
                text: "Register"
                font_size: "24sp"
                color: 0, 0, 0, 1
                size_hint_y: None
                height: dp(40)
            TextInput:
                id: first_name
                hint_text: "First Name"
                multiline: False
            TextInput:
                id: last_name
                hint_text: "Last Name"
                multiline: False
            TextInput:
                id: email
                hint_text: "Email"
                multiline: False
            TextInput:
                id: password
                hint_text: "Password"
                password: True
                multiline: False
            Button:
                text: "Create Account"
                size_hint_y: None
                height: dp(44)
                on_release: root.signup_user()
            Button:
                text: "Back to Login"
                size_hint_y: None
                height: dp(44)
                on_release: root.go_to_login()
        Footer:

<MainMenu>:
    name: "main_menu"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        BoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(15)
            Label:
                text: "Main Menu"
                font_size: "24sp"
                color: 0, 0, 0, 1
                size_hint_y: None
                height: dp(40)
            Button:
                text: "Play Game"
                size_hint_y: None
                height: dp(50)
                on_release: root.go_to_game()
            Button:
                text: "Profile"
                size_hint_y: None
                height: dp(50)
                on_release: root.go_to_profile()
            Button:
                text: "Settings"
                size_hint_y: None
                height: dp(50)
                on_release: root.manager.current = "settings"
            Button:
                text: "Help"
                size_hint_y: None
                height: dp(50)
                on_release: root.manager.current = "help"
            Button:
                text: "Logout"
                size_hint_y: None
                height: dp(50)
                on_release: root.logout()
        Footer:

<Profile>:
    name: "profile"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        ScrollView:
            BoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(10)
                size_hint_y: None
                height: self.minimum_height

                Label:
                    text: "Edit Profile"
                    font_size: "24sp"
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: dp(40)

                Label:
                    text: "First Name"
                    font_size: "16sp"
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: dp(30)
                    halign: "left"
                    text_size: self.size

                TextInput:
                    id: first_name
                    hint_text: "First Name"
                    multiline: False
                    size_hint_y: None
                    height: dp(40)

                Label:
                    text: "Last Name"
                    font_size: "16sp"
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: dp(30)
                    halign: "left"
                    text_size: self.size

                TextInput:
                    id: last_name
                    hint_text: "Last Name"
                    multiline: False
                    size_hint_y: None
                    height: dp(40)

                Label:
                    text: "Email"
                    font_size: "16sp"
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: dp(30)
                    halign: "left"
                    text_size: self.size

                TextInput:
                    id: email
                    hint_text: "Email"
                    multiline: False
                    size_hint_y: None
                    height: dp(40)

                Button:
                    text: "Save Changes"
                    size_hint_y: None
                    height: dp(50)
                    background_color: 0.12, 0.45, 0.88, 1
                    on_release: root.save_profile()

                # Score Table Section
                Widget:
                    size_hint_y: None
                    height: dp(20)

                Label:
                    text: "Leaderboard"
                    font_size: "20sp"
                    bold: True
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: dp(40)

                Label:
                    id: scores_table
                    text: "Loading scores..."
                    font_size: "16sp"
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: dp(150)
                    text_size: self.width, None
                    halign: "left"
                    valign: "top"

                Widget:
                    size_hint_y: None
                    height: dp(20)

                # Character colour picker (restored from old branch)
                Label:
                    text: "Choose Character Color:"
                    font_size: "18sp"
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: dp(36)
                    halign: "left"
                    text_size: self.size

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(10)
                    Button:
                        text: "White"
                        background_normal: ''
                        background_color: 0.85, 0.85, 0.85, 1
                        color: 0, 0, 0, 1
                        on_release: app.player_color = [1, 1, 1, 1]
                    Button:
                        text: "Red"
                        background_normal: ''
                        background_color: 1, 0.3, 0.3, 1
                        color: 1, 1, 1, 1
                        on_release: app.player_color = [1, 0.3, 0.3, 1]
                    Button:
                        text: "Blue"
                        background_normal: ''
                        background_color: 0.3, 0.5, 1, 1
                        color: 1, 1, 1, 1
                        on_release: app.player_color = [0.3, 0.5, 1, 1]
                    Button:
                        text: "Green"
                        background_normal: ''
                        background_color: 0.3, 1, 0.3, 1
                        color: 0, 0, 0, 1
                        on_release: app.player_color = [0.3, 1, 0.3, 1]

                Widget:
                    size_hint_y: None
                    height: dp(10)

                Button:
                    text: "Go to Settings"
                    size_hint_y: None
                    height: dp(44)
                    on_release: root.go_to_settings()

                Button:
                    text: "Back to Menu"
                    size_hint_y: None
                    height: dp(44)
                    on_release: root.manager.current = "main_menu"
        Footer:

<Settings>:
    name: "settings"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        BoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(10)
            Label:
                text: "Settings"
                font_size: "24sp"
                color: 0, 0, 0, 1
                size_hint_y: None
                height: dp(40)
            Widget:
                size_hint_y: 0.3
            Button:
                text: "Toggle Light/Dark Mode"
                size_hint_y: None
                height: dp(50)
                on_release: root.toggle_theme()
            Button:
                text: "Change Password"
                size_hint_y: None
                height: dp(50)
                on_release: root.show_change_password_dialog()
            Button:
                text: "Delete Account"
                size_hint_y: None
                height: dp(50)
                background_color: 1, 0.3, 0.3, 1
                on_release: root.show_delete_account_dialog()
            Widget:
                size_hint_y: 0.3
            Button:
                text: "Back to Menu"
                size_hint_y: None
                height: dp(44)
                on_release: root.manager.current = "main_menu"
        Footer:

<GameScreen>:
    name: "game"
    BoxLayout:
        orientation: "vertical"
        BoxLayout:
            id: game_container
            orientation: "vertical"
            # GameWidget is added programmatically in GameScreen.on_pre_enter()
        BoxLayout:
            size_hint_y: None
            height: dp(48)
            padding: dp(6)
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.1, 0.85
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: "Main Menu"
                size_hint_x: None
                width: dp(120)
                on_release: root.return_to_menu()

<HelpScreen>:
    name: "help"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        BoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(15)
            Label:
                text: "Help"
                font_size: "24sp"
                color: 0, 0, 0, 1
                size_hint_y: None
                height: dp(40)
            Label:
                text: "Use SPACE or ENTER to start the game and to jump.\nAvoid the red obstacles.\nSurvive as long as possible — you have 5 minutes!\nAfter the game, answer the reflection questions."
                font_size: "16sp"
                color: 0, 0, 0, 1
                halign: "left"
                text_size: self.width, None
            Widget:
            Button:
                text: "About"
                size_hint_y: None
                height: dp(44)
                on_release: root.show_about()
            Button:
                text: "Back to Menu"
                size_hint_y: None
                height: dp(44)
                on_release: root.manager.current = "main_menu"
        Footer:

# ===== REFLECTION SCREEN =====
<ReflectionScreen>:
    name: "reflection"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        BoxLayout:
            orientation: "vertical"
            padding: dp(24)
            spacing: dp(14)

            # --- Quiz section ---
            BoxLayout:
                id: quiz_box
                orientation: "vertical"
                spacing: dp(14)

                Label:
                    id: progress_label
                    text: ""
                    font_size: "16sp"
                    color: 0.4, 0.4, 0.4, 1
                    size_hint_y: None
                    height: dp(28)

                Label:
                    id: question_label
                    text: ""
                    font_size: "20sp"
                    bold: True
                    color: 0, 0, 0, 1
                    text_size: self.width, None
                    halign: "left"
                    size_hint_y: None
                    height: dp(80)

                GridLayout:
                    cols: 2
                    spacing: dp(10)
                    size_hint_y: None
                    height: dp(120)
                    Button:
                        id: choice_0
                        text: ""
                        on_release: root.on_choice(0)
                    Button:
                        id: choice_1
                        text: ""
                        on_release: root.on_choice(1)
                    Button:
                        id: choice_2
                        text: ""
                        on_release: root.on_choice(2)
                    Button:
                        id: choice_3
                        text: ""
                        on_release: root.on_choice(3)

            # --- Done section (hidden until quiz complete) ---
            BoxLayout:
                id: done_box
                orientation: "vertical"
                spacing: dp(20)
                opacity: 0
                disabled: True

                Label:
                    id: done_label
                    text: "Thank You for Playing!"
                    font_size: "22sp"
                    bold: True
                    color: 0, 0, 0, 1
                    halign: "center"
                    text_size: self.width, None
                    size_hint_y: None
                    height: dp(80)

                Button:
                    id: done_back_btn
                    text: "Play Again"
                    size_hint_y: None
                    height: dp(50)
                    background_color: 0.12, 0.45, 0.88, 1
                    on_release: root.go_back()

                Button:
                    id: menu_btn
                    text: "Main Menu"
                    size_hint_y: None
                    height: dp(50)
                    on_release: root.go_to_menu()

                Button:
                    id: menu_btn
                    text: "Main Menu"
                    size_hint_y: None
                    height: dp(50)
                    background_color: 0.12, 0.45, 0.88, 1
                    on_release: root.go_to_menu()
        Footer:
