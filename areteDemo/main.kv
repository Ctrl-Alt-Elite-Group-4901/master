#:kivy 2.2.0
#:import FadeTransition kivy.uix.screenmanager.FadeTransition
# ===== WIDGET TEMPLATES =====
<Header@BoxLayout>:
    size_hint_y: None
    height: dp(64)
    padding: dp(18), 0
    canvas.before:
        Color:
            rgba: app.theme_header
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: "Arete App"
        bold: True
        font_size: "22sp"
        color: 1, 1, 1, 1

<Footer@BoxLayout>:
    size_hint_y: None
    height: dp(42)
    padding: dp(12), 0
    canvas.before:
        Color:
            rgba: app.theme_footer
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: "Arete - v1.3"
        font_size: "13sp"
        color: app.theme_footer_text

<ScreenCard@BoxLayout>:
    orientation: "vertical"
    size_hint: None, None
    height: self.minimum_size[1]
    padding: dp(28)
    spacing: dp(14)
    canvas.before:
        Color:
            rgba: app.theme_card
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(22),]

<ScreenTitle@Label>:
    size_hint_y: None
    height: self.texture_size[1] + dp(6)
    font_size: "28sp"
    bold: True
    color: app.theme_text_primary
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<ScreenBodyText@Label>:
    size_hint_y: None
    height: self.texture_size[1]
    font_size: "15sp"
    color: app.theme_text_muted
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<FieldLabel@Label>:
    size_hint_y: None
    height: self.texture_size[1] + dp(2)
    font_size: "15sp"
    bold: True
    color: app.theme_text_primary
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<FormInput@TextInput>:
    size_hint_y: None
    height: dp(52)
    multiline: False
    write_tab: False
    font_size: "16sp"
    padding: [dp(14), dp(16), dp(14), dp(16)]
    background_normal: ""
    background_active: ""
    background_color: app.theme_input
    foreground_color: app.theme_text_primary
    hint_text_color: app.theme_text_muted
    cursor_color: app.theme_header

<PrimaryButton@Button>:
    size_hint_y: None
    height: dp(48)
    font_size: "16sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: app.theme_header
    color: 1, 1, 1, 1

<SecondaryButton@Button>:
    size_hint_y: None
    height: dp(48)
    font_size: "16sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: app.theme_button_secondary
    color: 1, 1, 1, 1

<DangerButton@Button>:
    size_hint_y: None
    height: dp(48)
    font_size: "16sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: app.theme_button_danger
    color: 1, 1, 1, 1

<BiomePanel@BoxLayout>:
    orientation: "vertical"
    size_hint: None, None
    height: self.minimum_size[1]
    padding: dp(30)
    spacing: dp(16)
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.46
        Rectangle:
            pos: self.x + dp(10), self.y - dp(10)
            size: self.size
        Color:
            rgba: 0.02, 0.03, 0.02, 0.92
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.08, 0.1, 0.09, 0.98
        Rectangle:
            pos: self.x + dp(8), self.y + dp(8)
            size: self.width - dp(16), self.height - dp(16)
    canvas.after:
        Color:
            rgba: 0.77, 1, 0.8, 1
        Line:
            width: dp(2)
            rectangle: (self.x, self.y, self.width, self.height)
        Rectangle:
            pos: self.x - dp(2), self.top - dp(10)
            size: dp(10), dp(10)
        Rectangle:
            pos: self.right - dp(8), self.top - dp(10)
            size: dp(10), dp(10)
        Rectangle:
            pos: self.x - dp(2), self.y
            size: dp(10), dp(10)
        Rectangle:
            pos: self.right - dp(8), self.y
            size: dp(10), dp(10)

<BiomeTextField@TextInput>:
    size_hint_y: None
    height: dp(56)
    multiline: False
    write_tab: False
    font_size: "16sp"
    padding: [dp(16), dp(16), dp(16), dp(16)]
    background_normal: ""
    background_active: ""
    background_color: (0.17, 0.19, 0.18, 0.98) if self.focus else (0.14, 0.16, 0.15, 0.98)
    foreground_color: 0.93, 0.96, 0.92, 1
    hint_text_color: 0.64, 0.68, 0.64, 1
    cursor_color: 0.77, 1, 0.8, 1
    selection_color: 0.41, 0.85, 1, 0.35
    canvas.after:
        Color:
            rgba: (0.77, 1, 0.8, 1) if self.focus else (0.28, 0.29, 0.26, 1)
        Line:
            width: dp(2)
            rectangle: (self.x, self.y, self.width, self.height)

<BiomePrimaryButton@Button>:
    size_hint_y: None
    height: dp(58)
    font_size: "17sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.0, 0.29, 0.13, 1
    text_size: self.width - dp(24), self.height
    halign: "center"
    valign: "middle"
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.58
        Rectangle:
            pos: self.x + dp(6), self.y - dp(6)
            size: self.size
        Color:
            rgba: (0.43, 0.99, 0.61, 1) if self.state == "down" else (0.77, 1, 0.8, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    canvas.after:
        Color:
            rgba: 0.02, 0.04, 0.03, 1
        Line:
            width: dp(2)
            rectangle: (self.x, self.y, self.width, self.height)

<BiomeAccentButton@Button>:
    size_hint_y: None
    height: dp(58)
    font_size: "18sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.0, 0.19, 0.24, 1
    text_size: self.width - dp(24), self.height
    halign: "center"
    valign: "middle"
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.58
        Rectangle:
            pos: self.x + dp(6), self.y - dp(6)
            size: self.size
        Color:
            rgba: (0.0, 0.75, 0.92, 1) if self.state == "down" else (0.41, 0.85, 1, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    canvas.after:
        Color:
            rgba: 0.02, 0.04, 0.05, 1
        Line:
            width: dp(2)
            rectangle: (self.x, self.y, self.width, self.height)

<BiomeSecondaryButton@Button>:
    size_hint_y: None
    height: dp(54)
    font_size: "16sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: (0.77, 1, 0.8, 1) if self.state == "normal" else (0.0, 0.29, 0.13, 1)
    text_size: self.width - dp(24), self.height
    halign: "center"
    valign: "middle"
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.48
        Rectangle:
            pos: self.x + dp(5), self.y - dp(5)
            size: self.size
        Color:
            rgba: (0.12, 0.14, 0.13, 0.96) if self.state == "normal" else (0.77, 1, 0.8, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    canvas.after:
        Color:
            rgba: 0.28, 0.29, 0.26, 1
        Line:
            width: dp(2)
            rectangle: (self.x, self.y, self.width, self.height)

<BiomeDangerButton@Button>:
    size_hint_y: None
    height: dp(54)
    font_size: "16sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 1, 0.94, 0.93, 1
    text_size: self.width - dp(24), self.height
    halign: "center"
    valign: "middle"
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.48
        Rectangle:
            pos: self.x + dp(5), self.y - dp(5)
            size: self.size
        Color:
            rgba: (0.7, 0.22, 0.14, 1) if self.state == "down" else (0.9, 0.36, 0.23, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    canvas.after:
        Color:
            rgba: 0.22, 0.06, 0.03, 1
        Line:
            width: dp(2)
            rectangle: (self.x, self.y, self.width, self.height)

<BiomePanelTitle@Label>:
    size_hint_y: None
    height: self.texture_size[1] + dp(4)
    font_size: "28sp"
    bold: True
    color: 0.89, 0.91, 0.87, 1
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<BiomeBodyLabel@Label>:
    size_hint_y: None
    height: self.texture_size[1] + dp(2)
    font_size: "15sp"
    color: 0.64, 0.68, 0.64, 1
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<BiomeFieldTag@Label>:
    size_hint_y: None
    height: self.texture_size[1]
    font_size: "12sp"
    bold: True
    color: 0.64, 0.68, 0.64, 1
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<BiomeDataLabel@Label>:
    size_hint_y: None
    height: max(dp(72), self.texture_size[1] + dp(6))
    font_size: "15sp"
    color: 0.89, 0.91, 0.87, 1
    halign: "left"
    valign: "top"
    text_size: self.width, None

<BiomeSwatchButton@Button>:
    size_hint_y: None
    height: dp(46)
    bold: True
    background_normal: ""
    background_down: ""
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.42
        Rectangle:
            pos: self.x + dp(4), self.y - dp(4)
            size: self.size
    canvas.after:
        Color:
            rgba: 0.02, 0.03, 0.02, 1
        Line:
            width: dp(2)
            rectangle: (self.x, self.y, self.width, self.height)

# ===== SCREEN DEFINITIONS =====

<Login>:
    name: "login"
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: app.login_background
        Color:
            rgba: 0.04, 0.05, 0.04, 0.76
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.77, 1, 0.8, 0.1
        Ellipse:
            pos: self.center_x - self.width * 0.48, self.center_y - self.width * 0.42
            size: self.width * 0.96, self.width * 0.96
        Color:
            rgba: 0.41, 0.85, 1, 0.08
        Ellipse:
            pos: self.x + self.width * 0.08, self.top - self.width * 0.4
            size: self.width * 0.42, self.width * 0.42
    FloatLayout:
        AnchorLayout:
            padding: dp(24), dp(28), dp(24), dp(24)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(520))
                Label:
                    size_hint_y: None
                    height: self.texture_size[1] + dp(2)
                    text: "ARETE"
                    font_size: "56sp"
                    bold: True
                    color: 0.77, 1, 0.8, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.width, None
                Widget:
                    size_hint_y: None
                    height: dp(10)
                Label:
                    size_hint_y: None
                    height: self.texture_size[1] + dp(2)
                    text: "WELCOME BACK"
                    font_size: "29sp"
                    bold: True
                    color: 0.89, 0.91, 0.87, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.width, None
                Widget:
                    size_hint_y: None
                    height: dp(10)
                    canvas.before:
                        Color:
                            rgba: 0.96, 0.73, 0.57, 1
                        Rectangle:
                            pos: self.center_x - dp(36), self.center_y - dp(1)
                            size: dp(72), dp(2)
                Label:
                    size_hint_y: None
                    height: self.texture_size[1]
                    text: "Sign in to continue your Arete session."
                    font_size: "15sp"
                    color: 0.64, 0.68, 0.64, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.width, None
                Widget:
                    size_hint_y: None
                    height: dp(6)
                Label:
                    size_hint_y: None
                    height: self.texture_size[1]
                    text: "IDENTITY TAG (EMAIL)"
                    font_size: "12sp"
                    bold: True
                    color: 0.64, 0.68, 0.64, 1
                    halign: "left"
                    valign: "middle"
                    text_size: self.width, None
                BiomeTextField:
                    id: email
                    hint_text: "explorer@arete.world"
                Label:
                    size_hint_y: None
                    height: self.texture_size[1]
                    text: "ACCESS KEY (PASSWORD)"
                    font_size: "12sp"
                    bold: True
                    color: 0.64, 0.68, 0.64, 1
                    halign: "left"
                    valign: "middle"
                    text_size: self.width, None
                BiomeTextField:
                    id: password
                    hint_text: "Enter your password"
                    password: True
                Widget:
                    size_hint_y: None
                    height: dp(6)
                BiomePrimaryButton:
                    text: "INITIALIZE SESSION"
                    on_release: root.login_user()
                BiomeSecondaryButton:
                    text: "CREATE AN ACCOUNT"
                    on_release: root.go_to_signup()

<Register>:
    name: "register"
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: app.login_background
        Color:
            rgba: 0.04, 0.05, 0.04, 0.78
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.41, 0.85, 1, 0.08
        Ellipse:
            pos: self.center_x - self.width * 0.5, self.center_y - self.width * 0.48
            size: self.width * 1.0, self.width * 1.0
    FloatLayout:
        AnchorLayout:
            padding: dp(24), dp(28), dp(24), dp(24)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(560))
                Label:
                    size_hint_y: None
                    height: self.texture_size[1] + dp(2)
                    text: "ARETE"
                    font_size: "54sp"
                    bold: True
                    color: 0.77, 1, 0.8, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.width, None
                Label:
                    size_hint_y: None
                    height: self.texture_size[1]
                    text: "NEW EXPLORER REGISTRATION"
                    font_size: "13sp"
                    bold: True
                    color: 0.41, 0.85, 1, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.width, None
                Widget:
                    size_hint_y: None
                    height: dp(8)
                BiomePanelTitle:
                    text: "CREATE ACCOUNT"
                    halign: "center"
                    text_size: self.width, None
                BiomeBodyLabel:
                    text: "Set up your profile so you can jump straight into the experience."
                    halign: "center"
                    text_size: self.width, None
                Widget:
                    size_hint_y: None
                    height: dp(4)
                GridLayout:
                    cols: 2 if self.width > dp(460) else 1
                    size_hint_y: None
                    height: self.minimum_size[1]
                    spacing: dp(12)
                    BoxLayout:
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_size[1]
                        spacing: dp(6)
                        BiomeFieldTag:
                            text: "FIRST NAME"
                        BiomeTextField:
                            id: first_name
                            hint_text: "First name"
                    BoxLayout:
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_size[1]
                        spacing: dp(6)
                        BiomeFieldTag:
                            text: "LAST NAME"
                        BiomeTextField:
                            id: last_name
                            hint_text: "Last name"
                BiomeFieldTag:
                    text: "EMAIL"
                BiomeTextField:
                    id: email
                    hint_text: "explorer@arete.world"
                BiomeFieldTag:
                    text: "PASSWORD"
                BiomeTextField:
                    id: password
                    hint_text: "Choose a password"
                    password: True
                Widget:
                    size_hint_y: None
                    height: dp(6)
                BiomePrimaryButton:
                    text: "CREATE ACCOUNT"
                    on_release: root.signup_user()
                BiomeSecondaryButton:
                    text: "BACK TO LOGIN"
                    on_release: root.go_to_login()
        BoxLayout:
            orientation: "vertical"
            size_hint: None, None
            width: dp(240)
            height: self.minimum_size[1]
            pos_hint: {"right": 0.97, "y": 0.05}
            spacing: dp(2)
            Label:
                size_hint_y: None
                height: self.texture_size[1]
                text: "IDENTITY LINK OPEN"
                font_size: "13sp"
                bold: True
                color: 0.96, 0.73, 0.57, 1
                halign: "right"
                valign: "middle"
                text_size: self.width, None
            Label:
                size_hint_y: None
                height: self.texture_size[1]
                text: "CREATE YOUR ARETE ACCESS NODE"
                font_size: "11sp"
                color: 0.64, 0.68, 0.64, 1
                halign: "right"
                valign: "middle"
                text_size: self.width, None

<MainMenu>:
    name: "main_menu"
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: app.menu_background
        Color:
            rgba: 0.04, 0.05, 0.04, 0.74
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.77, 1, 0.8, 0.08
        Ellipse:
            pos: self.center_x - self.width * 0.5, self.center_y - self.width * 0.45
            size: self.width * 1.0, self.width * 1.0
        Color:
            rgba: 0.96, 0.73, 0.57, 0.08
        Ellipse:
            pos: self.right - self.width * 0.36, self.y + self.height * 0.08
            size: self.width * 0.34, self.width * 0.34
    FloatLayout:
        BoxLayout:
            size_hint: 1, None
            height: dp(82)
            pos_hint: {"top": 1}
            padding: dp(24), dp(18), dp(24), dp(18)
            canvas.before:
                Color:
                    rgba: 0.02, 0.03, 0.02, 0.9
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.77, 1, 0.8, 1
                Line:
                    width: dp(2)
                    rectangle: (self.x, self.y, self.width, self.height)
            Label:
                text: "ARETE"
                font_size: "30sp"
                bold: True
                color: 0.77, 1, 0.8, 1
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                text: "MAIN MENU"
                font_size: "13sp"
                bold: True
                color: 0.41, 0.85, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
            Label:
                text: "SESSION ACTIVE"
                font_size: "13sp"
                bold: True
                color: 0.96, 0.73, 0.57, 1
                halign: "right"
                valign: "middle"
                text_size: self.size
        AnchorLayout:
            padding: dp(24), dp(92), dp(24), dp(92)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(560))
                Label:
                    size_hint_y: None
                    height: self.texture_size[1] + dp(2)
                    text: "ARETE"
                    font_size: "72sp"
                    bold: True
                    color: 0.77, 1, 0.8, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.width, None
                Label:
                    size_hint_y: None
                    height: self.texture_size[1]
                    text: "MAIN MENU"
                    font_size: "14sp"
                    bold: True
                    color: 0.96, 0.73, 0.57, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.width, None
                Label:
                    size_hint_y: None
                    height: self.texture_size[1]
                    text: "Choose where you want to go next."
                    font_size: "15sp"
                    color: 0.64, 0.68, 0.64, 1
                    halign: "center"
                    valign: "middle"
                    text_size: self.width, None
                Widget:
                    size_hint_y: None
                    height: dp(10)
                BiomeAccentButton:
                    text: "PLAY GAME"
                    on_release: root.go_to_game()
                BiomeSecondaryButton:
                    text: "PROFILE"
                    on_release: root.go_to_profile()
                BiomeSecondaryButton:
                    text: "SETTINGS"
                    on_release: root.manager.current = "settings"
                BiomeSecondaryButton:
                    text: "HELP"
                    on_release: root.manager.current = "help"
                Widget:
                    size_hint_y: None
                    height: dp(4)
                BiomeDangerButton:
                    text: "LOGOUT"
                    on_release: root.logout()

<Profile>:
    name: "profile"
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: app.menu_background
        Color:
            rgba: 0.04, 0.05, 0.04, 0.76
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.77, 1, 0.8, 0.07
        Ellipse:
            pos: self.center_x - self.width * 0.5, self.center_y - self.width * 0.45
            size: self.width * 1.0, self.width * 1.0
    FloatLayout:
        BoxLayout:
            size_hint: 1, None
            height: dp(82)
            pos_hint: {"top": 1}
            padding: dp(24), dp(18), dp(24), dp(18)
            canvas.before:
                Color:
                    rgba: 0.02, 0.03, 0.02, 0.9
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.77, 1, 0.8, 1
                Line:
                    width: dp(2)
                    rectangle: (self.x, self.y, self.width, self.height)
            Label:
                text: "ARETE"
                font_size: "30sp"
                bold: True
                color: 0.77, 1, 0.8, 1
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                text: "PROFILE"
                font_size: "13sp"
                bold: True
                color: 0.41, 0.85, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
            Label:
                text: "SESSION ACTIVE"
                font_size: "13sp"
                bold: True
                color: 0.96, 0.73, 0.57, 1
                halign: "right"
                valign: "middle"
                text_size: self.size
        ScrollView:
            size_hint: 1, 1
            pos_hint: {"x": 0, "y": 0}
            do_scroll_x: False
            bar_width: dp(8)
            GridLayout:
                cols: 1
                size_hint_y: None
                height: self.minimum_size[1]
                padding: dp(24), dp(104), dp(24), dp(24)
                spacing: dp(20)

                AnchorLayout:
                    size_hint_y: None
                    height: account_card.height
                    anchor_x: "center"
                    anchor_y: "top"
                    BiomePanel:
                        id: account_card
                        width: min(root.width - dp(48), dp(820))
                        BiomePanelTitle:
                            text: "Profile"
                        BiomeBodyLabel:
                            text: "Manage your account details and keep your information up to date."
                        Widget:
                            size_hint_y: None
                            height: dp(4)
                        GridLayout:
                            cols: 2 if self.width > dp(560) else 1
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(14)
                            BoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_size[1]
                                spacing: dp(6)
                                BiomeFieldTag:
                                    text: "FIRST NAME"
                                BiomeTextField:
                                    id: first_name
                                    hint_text: "First name"
                            BoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_size[1]
                                spacing: dp(6)
                                BiomeFieldTag:
                                    text: "LAST NAME"
                                BiomeTextField:
                                    id: last_name
                                    hint_text: "Last name"
                        BoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(6)
                            BiomeFieldTag:
                                text: "EMAIL"
                            BiomeTextField:
                                id: email
                                hint_text: "explorer@arete.world"
                        GridLayout:
                            cols: 2 if self.width > dp(560) else 1
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(12)
                            BiomePrimaryButton:
                                text: "SAVE CHANGES"
                                on_release: root.save_profile()
                            BiomeSecondaryButton:
                                text: "GO TO SETTINGS"
                                on_release: root.go_to_settings()
                        BiomeSecondaryButton:
                            text: "BACK TO MENU"
                            on_release: root.manager.current = "main_menu"

                AnchorLayout:
                    size_hint_y: None
                    height: progress_card.height
                    anchor_x: "center"
                    anchor_y: "top"
                    BiomePanel:
                        id: progress_card
                        width: min(root.width - dp(48), dp(820))
                        BiomePanelTitle:
                            text: "Progress and Style"
                        BiomeBodyLabel:
                            text: "Review your recent scores and pick the runner color you want to use in game."
                        Widget:
                            size_hint_y: None
                            height: dp(2)
                        BiomeFieldTag:
                            text: "LEADERBOARD"
                        BiomeDataLabel:
                            id: scores_table
                            text: "Loading scores..."
                            height: max(dp(140), self.texture_size[1] + dp(12))
                        BiomeFieldTag:
                            text: "CHOOSE CHARACTER COLOR"
                        GridLayout:
                            cols: 4 if self.width > dp(560) else 2
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(10)
                            BiomeSwatchButton:
                                text: "Orange"
                                background_color: 1.0, 0.6, 0.2, 1
                                color: 1, 1, 1, 1
                                on_release: app.player_color = [1.0, 0.6, 0.2, 1]
                            BiomeSwatchButton:
                                text: "Red"
                                background_color: 0.93, 0.36, 0.36, 1
                                color: 1, 1, 1, 1
                                on_release: app.player_color = [1, 0.3, 0.3, 1]
                            BiomeSwatchButton:
                                text: "Blue"
                                background_color: 0.32, 0.52, 0.95, 1
                                color: 1, 1, 1, 1
                                on_release: app.player_color = [0.3, 0.5, 1, 1]
                            BiomeSwatchButton:
                                text: "Green"
                                background_color: 0.36, 0.78, 0.39, 1
                                color: 1, 1, 1, 1
                                on_release: app.player_color = [0.3, 1, 0.3, 1]

<Settings>:
    name: "settings"
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: app.menu_background
        Color:
            rgba: 0.04, 0.05, 0.04, 0.76
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.41, 0.85, 1, 0.07
        Ellipse:
            pos: self.center_x - self.width * 0.46, self.center_y - self.width * 0.42
            size: self.width * 0.92, self.width * 0.92
    FloatLayout:
        BoxLayout:
            size_hint: 1, None
            height: dp(82)
            pos_hint: {"top": 1}
            padding: dp(24), dp(18), dp(24), dp(18)
            canvas.before:
                Color:
                    rgba: 0.02, 0.03, 0.02, 0.9
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.77, 1, 0.8, 1
                Line:
                    width: dp(2)
                    rectangle: (self.x, self.y, self.width, self.height)
            Label:
                text: "ARETE"
                font_size: "30sp"
                bold: True
                color: 0.77, 1, 0.8, 1
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                text: "SETTINGS"
                font_size: "13sp"
                bold: True
                color: 0.41, 0.85, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
            Label:
                text: "CONTROL PANEL"
                font_size: "13sp"
                bold: True
                color: 0.96, 0.73, 0.57, 1
                halign: "right"
                valign: "middle"
                text_size: self.size
        AnchorLayout:
            padding: dp(24), dp(92), dp(24), dp(24)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(560))
                BiomePanelTitle:
                    text: "Settings"
                BiomeBodyLabel:
                    text: "Adjust the visual theme and manage account actions from one place."
                Widget:
                    size_hint_y: None
                    height: dp(4)
                BiomeSecondaryButton:
                    text: "TOGGLE LIGHT / DARK MODE"
                    on_release: root.toggle_theme()
                BiomePrimaryButton:
                    text: "CHANGE PASSWORD"
                    on_release: root.show_change_password_dialog()
                BiomeDangerButton:
                    text: "DELETE ACCOUNT"
                    on_release: root.show_delete_account_dialog()
                BiomeSecondaryButton:
                    text: "BACK TO MENU"
                    on_release: root.manager.current = "main_menu"

<GameScreen>:
    name: "game"
    BoxLayout:
        id: game_container
        orientation: "vertical"
        # GameWidget is added programmatically in GameScreen.on_pre_enter()

<HelpScreen>:
    name: "help"
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: app.menu_background
        Color:
            rgba: 0.04, 0.05, 0.04, 0.76
        Rectangle:
            pos: self.pos
            size: self.size
    FloatLayout:
        BoxLayout:
            size_hint: 1, None
            height: dp(82)
            pos_hint: {"top": 1}
            padding: dp(24), dp(18), dp(24), dp(18)
            canvas.before:
                Color:
                    rgba: 0.02, 0.03, 0.02, 0.9
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.77, 1, 0.8, 1
                Line:
                    width: dp(2)
                    rectangle: (self.x, self.y, self.width, self.height)
            Label:
                text: "ARETE"
                font_size: "30sp"
                bold: True
                color: 0.77, 1, 0.8, 1
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                text: "HELP"
                font_size: "13sp"
                bold: True
                color: 0.41, 0.85, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
            Label:
                text: "RUN GUIDE"
                font_size: "13sp"
                bold: True
                color: 0.96, 0.73, 0.57, 1
                halign: "right"
                valign: "middle"
                text_size: self.size
        AnchorLayout:
            padding: dp(24), dp(92), dp(24), dp(24)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(680))
                BiomePanelTitle:
                    text: "Help"
                BiomeBodyLabel:
                    text: "Use SPACE or ENTER to start the game and jump. Avoid the red obstacles, survive for 5 minutes, and then complete the reflection questions."
                Widget:
                    size_hint_y: None
                    height: dp(2)
                BiomeFieldTag:
                    text: "QUICK START"
                BiomeDataLabel:
                    text: "1. Start your run from the main menu.\n2. Press SPACE or ENTER to jump.\n3. Dodge obstacles and survive long enough to unlock reflection.\n4. Finish the reflection quiz to complete the cycle."
                Widget:
                    size_hint_y: None
                    height: dp(4)
                BiomeSecondaryButton:
                    text: "ABOUT"
                    on_release: root.show_about()
                BiomeSecondaryButton:
                    text: "BACK TO MENU"
                    on_release: root.manager.current = "main_menu"

# ===== REFLECTION SCREEN =====
<ReflectionScreen>:
    name: "reflection"
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size
            source: app.menu_background
        Color:
            rgba: 0.04, 0.05, 0.04, 0.78
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.41, 0.85, 1, 0.06
        Ellipse:
            pos: self.center_x - self.width * 0.48, self.center_y - self.width * 0.44
            size: self.width * 0.96, self.width * 0.96
    FloatLayout:
        BoxLayout:
            size_hint: 1, None
            height: dp(82)
            pos_hint: {"top": 1}
            padding: dp(24), dp(18), dp(24), dp(18)
            canvas.before:
                Color:
                    rgba: 0.02, 0.03, 0.02, 0.9
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 0.77, 1, 0.8, 1
                Line:
                    width: dp(2)
                    rectangle: (self.x, self.y, self.width, self.height)
            Label:
                text: "ARETE"
                font_size: "30sp"
                bold: True
                color: 0.77, 1, 0.8, 1
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                text: "REFLECTION"
                font_size: "13sp"
                bold: True
                color: 0.41, 0.85, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
            Label:
                text: "MEMORY CHECK"
                font_size: "13sp"
                bold: True
                color: 0.96, 0.73, 0.57, 1
                halign: "right"
                valign: "middle"
                text_size: self.size
        AnchorLayout:
            padding: dp(24), dp(92), dp(24), dp(24)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(760))
                BiomePanelTitle:
                    text: "Reflection Quiz"
                BiomeBodyLabel:
                    text: "Recall what you noticed during the run and complete the cycle."
                Widget:
                    size_hint_y: None
                    height: dp(2)
                BoxLayout:
                    id: quiz_box
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_size[1] if not self.disabled else 0
                    spacing: dp(14)
                    opacity: 1 if not self.disabled else 0

                    BiomeFieldTag:
                        id: quiz_title
                        text: "REFLECTION"
                        height: self.texture_size[1] if not quiz_box.disabled else 0
                        opacity: 1 if not quiz_box.disabled else 0

                    BiomeBodyLabel:
                        id: progress_label
                        text: ""
                        height: self.texture_size[1] + dp(2) if not quiz_box.disabled else 0
                        opacity: 1 if not quiz_box.disabled else 0

                    BiomePanelTitle:
                        id: question_label
                        text: ""
                        font_size: "24sp"
                        height: max(dp(92), self.texture_size[1] + dp(4)) if not quiz_box.disabled else 0
                        opacity: 1 if not quiz_box.disabled else 0

                    GridLayout:
                        id: choices_grid
                        cols: 2 if self.width > dp(520) else 1
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_size[1] if not quiz_box.disabled else 0
                        opacity: 1 if not quiz_box.disabled else 0
                        BiomeSecondaryButton:
                            id: choice_0
                            text: ""
                            height: dp(56)
                            on_release: root.on_choice(0)
                        BiomeSecondaryButton:
                            id: choice_1
                            text: ""
                            height: dp(56)
                            on_release: root.on_choice(1)
                        BiomeSecondaryButton:
                            id: choice_2
                            text: ""
                            height: dp(56)
                            on_release: root.on_choice(2)
                        BiomeSecondaryButton:
                            id: choice_3
                            text: ""
                            height: dp(56)
                            on_release: root.on_choice(3)

                BoxLayout:
                    id: done_box
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_size[1] if not self.disabled else 0
                    spacing: dp(16)
                    opacity: 0
                    disabled: True

                    BiomePanelTitle:
                        id: done_label
                        text: "Thank You for Playing!"
                        font_size: "24sp"
                        halign: "center"
                        text_size: self.width, None
                        height: max(dp(96), self.texture_size[1] + dp(8)) if not done_box.disabled else 0
                        opacity: 1 if not done_box.disabled else 0

                    BiomePrimaryButton:
                        id: done_back_btn
                        text: "Play Again"
                        height: dp(56) if not done_box.disabled else 0
                        opacity: 1 if not done_box.disabled else 0
                        on_release: root.go_back()

                    BiomeSecondaryButton:
                        id: menu_btn
                        text: "Main Menu"
                        height: dp(54) if not done_box.disabled else 0
                        opacity: 1 if not done_box.disabled else 0
                        on_release: root.go_to_menu()

# ===== EDITOR MENU SCREEN (DEV MODE ONLY) =====
<EditorMenu>:
    name: "editor_menu"
    canvas.before:
        # Dark charcoal base — visually distinct from normal user screens
        Color:
            rgba: 0.07, 0.07, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        # Amber glow ellipse — dev accent color
        Color:
            rgba: 1, 0.72, 0.1, 0.07
        Ellipse:
            pos: self.center_x - self.width * 0.5, self.center_y - self.width * 0.45
            size: self.width * 1.0, self.width * 1.0
    FloatLayout:
        # ── Top bar ──────────────────────────────────────────────────────
        BoxLayout:
            size_hint: 1, None
            height: dp(82)
            pos_hint: {"top": 1}
            padding: dp(24), dp(18), dp(24), dp(18)
            canvas.before:
                Color:
                    rgba: 0.10, 0.09, 0.06, 0.96
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 1, 0.72, 0.1, 1
                Line:
                    width: dp(2)
                    rectangle: (self.x, self.y, self.width, self.height)
            Label:
                text: "ARETE"
                font_size: "30sp"
                bold: True
                color: 1, 0.72, 0.1, 1
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                text: "EDITOR"
                font_size: "13sp"
                bold: True
                color: 0.41, 0.85, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
            Label:
                text: "⚙  DEV MODE"
                font_size: "13sp"
                bold: True
                color: 1, 0.72, 0.1, 1
                halign: "right"
                valign: "middle"
                text_size: self.size
        # ── Content panel ────────────────────────────────────────────────
        AnchorLayout:
            padding: dp(24), dp(92), dp(24), dp(24)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(560))
                BiomePanelTitle:
                    text: "Editor Hub"
                    color: 1, 0.72, 0.1, 1
                BiomeBodyLabel:
                    text: "Select a page to open. These pages are only visible in dev mode."
                Widget:
                    size_hint_y: None
                    height: dp(8)
                BiomePrimaryButton:
                    text: "MEMORY QUESTIONS"
                    canvas.before:
                        Color:
                            rgba: 0, 0, 0, 0.58
                        Rectangle:
                            pos: self.x + dp(6), self.y - dp(6)
                            size: self.size
                        Color:
                            rgba: (0.85, 0.55, 0.0, 1) if self.state == "down" else (1, 0.72, 0.1, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    on_release: root.go_to_page(1)
                BiomePrimaryButton:
                    text: "EDITOR PAGE 2"
                    canvas.before:
                        Color:
                            rgba: 0, 0, 0, 0.58
                        Rectangle:
                            pos: self.x + dp(6), self.y - dp(6)
                            size: self.size
                        Color:
                            rgba: (0.85, 0.55, 0.0, 1) if self.state == "down" else (1, 0.72, 0.1, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    on_release: root.go_to_page(2)
                BiomePrimaryButton:
                    text: "EDITOR PAGE 3"
                    canvas.before:
                        Color:
                            rgba: 0, 0, 0, 0.58
                        Rectangle:
                            pos: self.x + dp(6), self.y - dp(6)
                            size: self.size
                        Color:
                            rgba: (0.85, 0.55, 0.0, 1) if self.state == "down" else (1, 0.72, 0.1, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    on_release: root.go_to_page(3)
                BiomePrimaryButton:
                    text: "EDITOR PAGE 4"
                    canvas.before:
                        Color:
                            rgba: 0, 0, 0, 0.58
                        Rectangle:
                            pos: self.x + dp(6), self.y - dp(6)
                            size: self.size
                        Color:
                            rgba: (0.85, 0.55, 0.0, 1) if self.state == "down" else (1, 0.72, 0.1, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    on_release: root.go_to_page(4)
                Widget:
                    size_hint_y: None
                    height: dp(4)
                BiomeSecondaryButton:
                    text: "BACK TO MENU"
                    on_release: root.go_back()

# ===== MEMORY QUESTION EDITOR (DEV MODE ONLY) =====
<MemoryQuestionEditor>:
    canvas.before:
        Color:
            rgba: 0.07, 0.07, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 0.72, 0.1, 0.05
        Ellipse:
            pos: self.center_x - self.width * 0.48, self.center_y - self.width * 0.44
            size: self.width * 0.96, self.width * 0.96
    FloatLayout:
        BoxLayout:
            size_hint: 1, None
            height: dp(82)
            pos_hint: {"top": 1}
            padding: dp(24), dp(18), dp(24), dp(18)
            canvas.before:
                Color:
                    rgba: 0.10, 0.09, 0.06, 0.96
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 1, 0.72, 0.1, 1
                Line:
                    width: dp(2)
                    rectangle: (self.x, self.y, self.width, self.height)
            Label:
                text: "ARETE"
                font_size: "30sp"
                bold: True
                color: 1, 0.72, 0.1, 1
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                text: root.page_title.upper()
                font_size: "13sp"
                bold: True
                color: 0.41, 0.85, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
            Label:
                text: "⚙  DEV MODE"
                font_size: "13sp"
                bold: True
                color: 1, 0.72, 0.1, 1
                halign: "right"
                valign: "middle"
                text_size: self.size
        AnchorLayout:
            padding: dp(24), dp(92), dp(24), dp(24)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(1040))
                BiomePanelTitle:
                    text: "Memory Question Editor"
                    color: 1, 0.72, 0.1, 1
                BiomeBodyLabel:
                    text: "Create, update, and remove reflection quiz questions used after gameplay."
                BiomeBodyLabel:
                    text: root.status_text
                    color: 0.41, 0.85, 1, 1
                ScrollView:
                    size_hint_y: None
                    height: min(root.height - dp(290), dp(520))
                    do_scroll_x: False
                    bar_width: dp(8)
                    GridLayout:
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_size[1]
                        spacing: dp(10)

                        BiomeFieldTag:
                            text: "EDIT QUESTION BY NUMBER (1-BASED)"
                        BoxLayout:
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(10)
                            BiomeTextField:
                                id: selected_index_input
                                hint_text: "e.g. 1"
                                size_hint_x: 0.35
                            BiomeSecondaryButton:
                                text: "LOAD SELECTED"
                                size_hint_x: 0.65
                                on_release: root.load_selected()

                        BiomeFieldTag:
                            text: "QUESTION TEXT"
                        BiomeTextField:
                            id: question_text
                            multiline: True
                            height: dp(96)
                            hint_text: "What should players remember from gameplay?"

                        BiomeFieldTag:
                            text: "CHOICE 1"
                        BiomeTextField:
                            id: choice_1
                            hint_text: "Choice 1"
                        BiomeFieldTag:
                            text: "CHOICE 2"
                        BiomeTextField:
                            id: choice_2
                            hint_text: "Choice 2"
                        BiomeFieldTag:
                            text: "CHOICE 3"
                        BiomeTextField:
                            id: choice_3
                            hint_text: "Choice 3"
                        BiomeFieldTag:
                            text: "CHOICE 4"
                        BiomeTextField:
                            id: choice_4
                            hint_text: "Choice 4"
                        BiomeFieldTag:
                            text: "CORRECT CHOICE (1-4)"
                        BiomeTextField:
                            id: correct_choice_input
                            hint_text: "Enter 1, 2, 3, or 4"

                        GridLayout:
                            cols: 2 if self.width > dp(640) else 1
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(10)
                            BiomePrimaryButton:
                                text: "SAVE SELECTED QUESTION"
                                on_release: root.save_selected()
                            BiomePrimaryButton:
                                text: "ADD NEW QUESTION"
                                on_release: root.add_question()
                            BiomeDangerButton:
                                text: "REMOVE SELECTED QUESTION"
                                on_release: root.remove_selected()
                            BiomeSecondaryButton:
                                text: "RESET TO DEFAULT QUESTIONS"
                                on_release: root.reset_defaults()

                        BiomeFieldTag:
                            text: "CURRENT QUESTION SET"
                        BiomeDataLabel:
                            text: root.question_list_text
                            height: max(dp(220), self.texture_size[1] + dp(10))

                BiomeSecondaryButton:
                    text: "BACK TO EDITOR HUB"
                    on_release: root.go_back()

# ===== EDITOR PAGE SCREEN (DEV MODE ONLY) =====
<EditorPage>:
    canvas.before:
        Color:
            rgba: 0.07, 0.07, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 1, 0.72, 0.1, 0.05
        Ellipse:
            pos: self.center_x - self.width * 0.48, self.center_y - self.width * 0.44
            size: self.width * 0.96, self.width * 0.96
    FloatLayout:
        # ── Top bar ──────────────────────────────────────────────────────
        BoxLayout:
            size_hint: 1, None
            height: dp(82)
            pos_hint: {"top": 1}
            padding: dp(24), dp(18), dp(24), dp(18)
            canvas.before:
                Color:
                    rgba: 0.10, 0.09, 0.06, 0.96
                Rectangle:
                    pos: self.pos
                    size: self.size
            canvas.after:
                Color:
                    rgba: 1, 0.72, 0.1, 1
                Line:
                    width: dp(2)
                    rectangle: (self.x, self.y, self.width, self.height)
            Label:
                text: "ARETE"
                font_size: "30sp"
                bold: True
                color: 1, 0.72, 0.1, 1
                halign: "left"
                valign: "middle"
                text_size: self.size
            Label:
                text: root.page_title.upper()
                font_size: "13sp"
                bold: True
                color: 0.41, 0.85, 1, 1
                halign: "center"
                valign: "middle"
                text_size: self.size
            Label:
                text: "⚙  DEV MODE"
                font_size: "13sp"
                bold: True
                color: 1, 0.72, 0.1, 1
                halign: "right"
                valign: "middle"
                text_size: self.size
        # ── Placeholder content ──────────────────────────────────────────
        AnchorLayout:
            padding: dp(24), dp(92), dp(24), dp(24)
            anchor_x: "center"
            anchor_y: "center"
            BiomePanel:
                width: min(root.width - dp(48), dp(560))
                BiomePanelTitle:
                    text: root.page_title
                    color: 1, 0.72, 0.1, 1
                BiomeFieldTag:
                    text: "PLACEHOLDER"
                    color: 1, 0.72, 0.1, 0.8
                BiomeBodyLabel:
                    text: "This page is reserved for developer content.\nA team member will implement this screen."
                Widget:
                    size_hint_y: None
                    height: dp(12)
                BiomeSecondaryButton:
                    text: "BACK TO EDITOR HUB"
                    on_release: root.go_back()

# ===== MAIN MENU — EDITOR BUTTON (DEV MODE ONLY) =====
# This rule extends MainMenu with an Editor button that is invisible
# and non-interactive for normal users. Binding both opacity and
# disabled to is_dev_mode means it truly does not exist for non-devs.
<MainMenu>:
    # Editor button floated over the existing panel, bottom-right corner.
    # It appears only when app.is_dev_mode is True.
    BoxLayout:
        size_hint: None, None
        width: dp(180)
        height: dp(54)
        pos_hint: {"right": 0.98, "y": 0.02}
        opacity: 1 if app.is_dev_mode else 0
        disabled: not app.is_dev_mode
        canvas.before:
            Color:
                rgba: 0, 0, 0, 0.48 if app.is_dev_mode else 0
            Rectangle:
                pos: self.x + dp(5), self.y - dp(5)
                size: self.size
            Color:
                rgba: (1, 0.72, 0.1, 1) if app.is_dev_mode else (0, 0, 0, 0)
            Rectangle:
                pos: self.pos
                size: self.size
        canvas.after:
            Color:
                rgba: 0.5, 0.35, 0.0, 1 if app.is_dev_mode else 0
            Line:
                width: dp(2)
                rectangle: (self.x, self.y, self.width, self.height)
        Button:
            text: "⚙  EDITOR"
            bold: True
            font_size: "15sp"
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            color: 0.1, 0.07, 0.0, 1
            on_release: root.go_to_editor()
