#:kivy 2.2.0
#:import FadeTransition kivy.uix.screenmanager.FadeTransition
# ===== WIDGET TEMPLATES =====
<Header@BoxLayout>:
    size_hint_y: None
    height: dp(64)
    padding: dp(18), 0
    canvas.before:
        Color:
            rgba: app.theme_header
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: "Arete App"
        bold: True
        font_size: "22sp"
        color: 1, 1, 1, 1

<Footer@BoxLayout>:
    size_hint_y: None
    height: dp(42)
    padding: dp(12), 0
    canvas.before:
        Color:
            rgba: app.theme_footer
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: "Arete - v1.3"
        font_size: "13sp"
        color: app.theme_footer_text

<ScreenCard@BoxLayout>:
    orientation: "vertical"
    size_hint: None, None
    height: self.minimum_size[1]
    padding: dp(28)
    spacing: dp(14)
    canvas.before:
        Color:
            rgba: app.theme_card
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(22),]

<ScreenTitle@Label>:
    size_hint_y: None
    height: self.texture_size[1] + dp(6)
    font_size: "28sp"
    bold: True
    color: app.theme_text_primary
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<ScreenBodyText@Label>:
    size_hint_y: None
    height: self.texture_size[1]
    font_size: "15sp"
    color: app.theme_text_muted
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<FieldLabel@Label>:
    size_hint_y: None
    height: self.texture_size[1] + dp(2)
    font_size: "15sp"
    bold: True
    color: app.theme_text_primary
    halign: "left"
    valign: "middle"
    text_size: self.width, None

<FormInput@TextInput>:
    size_hint_y: None
    height: dp(52)
    multiline: False
    write_tab: False
    font_size: "16sp"
    padding: [dp(14), dp(16), dp(14), dp(16)]
    background_normal: ""
    background_active: ""
    background_color: app.theme_input
    foreground_color: app.theme_text_primary
    hint_text_color: app.theme_text_muted
    cursor_color: app.theme_header

<PrimaryButton@Button>:
    size_hint_y: None
    height: dp(48)
    font_size: "16sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: app.theme_header
    color: 1, 1, 1, 1

<SecondaryButton@Button>:
    size_hint_y: None
    height: dp(48)
    font_size: "16sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: app.theme_button_secondary
    color: 1, 1, 1, 1

<DangerButton@Button>:
    size_hint_y: None
    height: dp(48)
    font_size: "16sp"
    bold: True
    background_normal: ""
    background_down: ""
    background_color: app.theme_button_danger
    color: 1, 1, 1, 1

# ===== SCREEN DEFINITIONS =====

<Login>:
    name: "login"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        AnchorLayout:
            padding: dp(24)
            anchor_x: "center"
            anchor_y: "center"
            ScreenCard:
                width: min(root.width - dp(48), dp(460))
                ScreenTitle:
                    text: "Welcome Back"
                ScreenBodyText:
                    text: "Sign in to continue your Arete session."
                Widget:
                    size_hint_y: None
                    height: dp(4)
                FieldLabel:
                    text: "Email"
                FormInput:
                    id: email
                    hint_text: "name@example.com"
                FieldLabel:
                    text: "Password"
                FormInput:
                    id: password
                    hint_text: "Password"
                    password: True
                Widget:
                    size_hint_y: None
                    height: dp(4)
                PrimaryButton:
                    text: "Login"
                    on_release: root.login_user()
                SecondaryButton:
                    text: "Create an Account"
                    on_release: root.go_to_signup()
        Footer:

<Register>:
    name: "register"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        AnchorLayout:
            padding: dp(24)
            anchor_x: "center"
            anchor_y: "center"
            ScreenCard:
                width: min(root.width - dp(48), dp(520))
                ScreenTitle:
                    text: "Create Account"
                ScreenBodyText:
                    text: "Set up your profile so you can jump straight into the experience."
                Widget:
                    size_hint_y: None
                    height: dp(4)
                FieldLabel:
                    text: "First Name"
                FormInput:
                    id: first_name
                    hint_text: "First name"
                FieldLabel:
                    text: "Last Name"
                FormInput:
                    id: last_name
                    hint_text: "Last name"
                FieldLabel:
                    text: "Email"
                FormInput:
                    id: email
                    hint_text: "name@example.com"
                FieldLabel:
                    text: "Password"
                FormInput:
                    id: password
                    hint_text: "Choose a password"
                    password: True
                Widget:
                    size_hint_y: None
                    height: dp(4)
                PrimaryButton:
                    text: "Create Account"
                    on_release: root.signup_user()
                SecondaryButton:
                    text: "Back to Login"
                    on_release: root.go_to_login()
        Footer:

<MainMenu>:
    name: "main_menu"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        AnchorLayout:
            padding: dp(24)
            anchor_x: "center"
            anchor_y: "center"
            ScreenCard:
                width: min(root.width - dp(48), dp(520))
                ScreenTitle:
                    text: "Main Menu"
                ScreenBodyText:
                    text: "Choose where you want to go next."
                Widget:
                    size_hint_y: None
                    height: dp(4)
                PrimaryButton:
                    text: "Play Game"
                    on_release: root.go_to_game()
                SecondaryButton:
                    text: "Profile"
                    on_release: root.go_to_profile()
                SecondaryButton:
                    text: "Settings"
                    on_release: root.manager.current = "settings"
                SecondaryButton:
                    text: "Help"
                    on_release: root.manager.current = "help"
                DangerButton:
                    text: "Logout"
                    on_release: root.logout()
        Footer:

<Profile>:
    name: "profile"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        ScrollView:
            do_scroll_x: False
            bar_width: dp(8)
            GridLayout:
                cols: 1
                size_hint_y: None
                height: self.minimum_size[1]
                padding: dp(24)
                spacing: dp(20)

                AnchorLayout:
                    size_hint_y: None
                    height: account_card.height
                    anchor_x: "center"
                    anchor_y: "top"
                    ScreenCard:
                        id: account_card
                        width: min(root.width - dp(48), dp(760))
                        ScreenTitle:
                            text: "Profile"
                        ScreenBodyText:
                            text: "Manage your account details and keep your information up to date."
                        Widget:
                            size_hint_y: None
                            height: dp(4)
                        GridLayout:
                            cols: 2 if self.width > dp(560) else 1
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(14)
                            BoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_size[1]
                                spacing: dp(6)
                                FieldLabel:
                                    text: "First Name"
                                FormInput:
                                    id: first_name
                                    hint_text: "First name"
                            BoxLayout:
                                orientation: "vertical"
                                size_hint_y: None
                                height: self.minimum_size[1]
                                spacing: dp(6)
                                FieldLabel:
                                    text: "Last Name"
                                FormInput:
                                    id: last_name
                                    hint_text: "Last name"
                        BoxLayout:
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(6)
                            FieldLabel:
                                text: "Email"
                            FormInput:
                                id: email
                                hint_text: "name@example.com"
                        GridLayout:
                            cols: 2 if self.width > dp(560) else 1
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(12)
                            PrimaryButton:
                                text: "Save Changes"
                                on_release: root.save_profile()
                            SecondaryButton:
                                text: "Go to Settings"
                                on_release: root.go_to_settings()
                        SecondaryButton:
                            text: "Back to Menu"
                            on_release: root.manager.current = "main_menu"

                AnchorLayout:
                    size_hint_y: None
                    height: progress_card.height
                    anchor_x: "center"
                    anchor_y: "top"
                    ScreenCard:
                        id: progress_card
                        width: min(root.width - dp(48), dp(760))
                        ScreenTitle:
                            text: "Progress and Style"
                        ScreenBodyText:
                            text: "Review your recent scores and pick the runner color you want to use in game."
                        Widget:
                            size_hint_y: None
                            height: dp(2)
                        FieldLabel:
                            text: "Leaderboard"
                        Label:
                            id: scores_table
                            text: "Loading scores..."
                            size_hint_y: None
                            height: max(dp(140), self.texture_size[1] + dp(20))
                            font_size: "16sp"
                            color: app.theme_text_primary
                            halign: "left"
                            valign: "top"
                            text_size: self.width, None
                        FieldLabel:
                            text: "Choose Character Color"
                        GridLayout:
                            cols: 4 if self.width > dp(560) else 2
                            size_hint_y: None
                            height: self.minimum_size[1]
                            spacing: dp(10)
                            Button:
                                text: "White"
                                size_hint_y: None
                                height: dp(46)
                                bold: True
                                background_normal: ""
                                background_down: ""
                                background_color: 0.88, 0.88, 0.9, 1
                                color: 0.08, 0.08, 0.08, 1
                                on_release: app.player_color = [1, 1, 1, 1]
                            Button:
                                text: "Red"
                                size_hint_y: None
                                height: dp(46)
                                bold: True
                                background_normal: ""
                                background_down: ""
                                background_color: 0.93, 0.36, 0.36, 1
                                color: 1, 1, 1, 1
                                on_release: app.player_color = [1, 0.3, 0.3, 1]
                            Button:
                                text: "Blue"
                                size_hint_y: None
                                height: dp(46)
                                bold: True
                                background_normal: ""
                                background_down: ""
                                background_color: 0.32, 0.52, 0.95, 1
                                color: 1, 1, 1, 1
                                on_release: app.player_color = [0.3, 0.5, 1, 1]
                            Button:
                                text: "Green"
                                size_hint_y: None
                                height: dp(46)
                                bold: True
                                background_normal: ""
                                background_down: ""
                                background_color: 0.36, 0.78, 0.39, 1
                                color: 1, 1, 1, 1
                                on_release: app.player_color = [0.3, 1, 0.3, 1]
        Footer:

<Settings>:
    name: "settings"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        AnchorLayout:
            padding: dp(24)
            anchor_x: "center"
            anchor_y: "center"
            ScreenCard:
                width: min(root.width - dp(48), dp(560))
                ScreenTitle:
                    text: "Settings"
                ScreenBodyText:
                    text: "Adjust the visual theme and manage account actions from one place."
                Widget:
                    size_hint_y: None
                    height: dp(4)
                SecondaryButton:
                    text: "Toggle Light/Dark Mode"
                    on_release: root.toggle_theme()
                SecondaryButton:
                    text: "Change Password"
                    on_release: root.show_change_password_dialog()
                DangerButton:
                    text: "Delete Account"
                    on_release: root.show_delete_account_dialog()
                SecondaryButton:
                    text: "Back to Menu"
                    on_release: root.manager.current = "main_menu"
        Footer:

<GameScreen>:
    name: "game"
    BoxLayout:
        id: game_container
        orientation: "vertical"
        # GameWidget is added programmatically in GameScreen.on_pre_enter()

<HelpScreen>:
    name: "help"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        AnchorLayout:
            padding: dp(24)
            anchor_x: "center"
            anchor_y: "center"
            ScreenCard:
                width: min(root.width - dp(48), dp(680))
                ScreenTitle:
                    text: "Help"
                ScreenBodyText:
                    text: "Use SPACE or ENTER to start the game and jump. Avoid the red obstacles, survive for 5 minutes, and then complete the reflection questions."
                Widget:
                    size_hint_y: None
                    height: dp(4)
                SecondaryButton:
                    text: "About"
                    on_release: root.show_about()
                SecondaryButton:
                    text: "Back to Menu"
                    on_release: root.manager.current = "main_menu"
        Footer:

# ===== REFLECTION SCREEN =====
<ReflectionScreen>:
    name: "reflection"
    canvas.before:
        Color:
            rgba: app.theme_background
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        Header:
        AnchorLayout:
            padding: dp(24)
            anchor_x: "center"
            anchor_y: "center"
            ScreenCard:
                width: min(root.width - dp(48), dp(760))
                BoxLayout:
                    id: quiz_box
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(318) if not self.disabled else 0
                    spacing: dp(14)

                    Label:
                        id: quiz_title
                        text: "Reflection"
                        font_size: "24sp"
                        bold: True
                        color: app.theme_text_primary
                        size_hint_y: None
                        height: dp(40) if not quiz_box.disabled else 0
                        opacity: 1 if not quiz_box.disabled else 0
                        halign: "left"
                        valign: "middle"
                        text_size: self.width, None

                    Label:
                        id: progress_label
                        text: ""
                        font_size: "16sp"
                        color: app.theme_text_muted
                        size_hint_y: None
                        height: dp(28) if not quiz_box.disabled else 0
                        opacity: 1 if not quiz_box.disabled else 0
                        halign: "left"
                        text_size: self.width, None

                    Label:
                        id: question_label
                        text: ""
                        font_size: "20sp"
                        bold: True
                        color: app.theme_text_primary
                        text_size: self.width, None
                        halign: "left"
                        valign: "middle"
                        size_hint_y: None
                        height: dp(88) if not quiz_box.disabled else 0
                        opacity: 1 if not quiz_box.disabled else 0

                    GridLayout:
                        id: choices_grid
                        cols: 2
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(120) if not quiz_box.disabled else 0
                        opacity: 1 if not quiz_box.disabled else 0
                        PrimaryButton:
                            id: choice_0
                            text: ""
                            on_release: root.on_choice(0)
                        PrimaryButton:
                            id: choice_1
                            text: ""
                            on_release: root.on_choice(1)
                        PrimaryButton:
                            id: choice_2
                            text: ""
                            on_release: root.on_choice(2)
                        PrimaryButton:
                            id: choice_3
                            text: ""
                            on_release: root.on_choice(3)

                BoxLayout:
                    id: done_box
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(232) if not self.disabled else 0
                    spacing: dp(20)
                    opacity: 0
                    disabled: True

                    Label:
                        id: done_label
                        text: "Thank You for Playing!"
                        font_size: "22sp"
                        bold: True
                        color: app.theme_text_primary
                        halign: "center"
                        valign: "middle"
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(96) if not done_box.disabled else 0
                        opacity: 1 if not done_box.disabled else 0

                    PrimaryButton:
                        id: done_back_btn
                        text: "Play Again"
                        height: dp(48) if not done_box.disabled else 0
                        opacity: 1 if not done_box.disabled else 0
                        on_release: root.go_back()

                    SecondaryButton:
                        id: menu_btn
                        text: "Main Menu"
                        height: dp(48) if not done_box.disabled else 0
                        opacity: 1 if not done_box.disabled else 0
                        on_release: root.go_to_menu()
        Footer:
